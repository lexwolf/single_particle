# Ignore everything inside data/output and img and bin
data/output/*
data/output/oGp/*
img/*
img/oGp/*
img/oGp/pdf/*
img/GIF/*
img/alp_p3_emi/*
bin/*
data/input/*.bak

# But track the directories themselves
!data/output/.gitkeep
!data/output/oGp/.gitkeep
!img/.gitkeep
!img/oGp/.gitkeep
!img/oGp/pdf/.gitkeep
!img/GIF/.gitkeep
!img/alp_p3_emi/.gitkeep
!bin/.gitkeep

# Ignore *.o and *.so files
src/*.o

# Editor swap / temp files
*.swp
*.swo
*.kate-swp
.*.kate-swp

# Ignore build intermediates accidentally created under include/
include/**/*.o
include/**/*.obj
include/**/*.a
include/**/*.so
include/**/*.d
include/**/*.lo
include/**/*.la
include/**/*.mod
include/**/*.pcm

# Ignore test executables generated in tests/
tests/time_behavior
tests/time_behavior_Q
tests/steady_state
tests/threshold
tests/tim
tests/timQ
tests/sts
tests/trs
